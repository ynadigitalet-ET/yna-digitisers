DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/app_db"

# Admin login for /admin/login (fill these in your real .env)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# Local Ethiopian payment display
TELEBIRR_PHONE="+251 908 029 753"
TELEBIRR_NAME="Yohannes Nigatu"

# Optional Stripe Payment Links for pricing buttons
STRIPE_STARTER_PAYMENT_LINK=""
STRIPE_PROFESSIONAL_PAYMENT_LINK=""
STRIPE_ENTERPRISE_PAYMENT_LINK=""

# Optional Tawk.to chat widget
NEXT_PUBLIC_TAWK_PROPERTY_ID=""
NEXT_PUBLIC_TAWK_WIDGET_ID=""

# Gmail SMTP (required for transactional emails: newsletter welcome,
# approval/denial notices, and internal admin notifications).
# SMTP_USER must be a full Gmail address, and SMTP_PASS must be a
# 16-character Gmail "App Password" (NOT your normal Gmail password).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="\"YNA Digitisers\" <ynadigital.et@gmail.com>"

# Used as the "Visit YNA Digitisers" link and logo URL inside emails.
NEXT_PUBLIC_SITE_URL="https://ynadigitisers.com"

# Cloudflare Turnstile (human verification for all public forms & admin login).
# Get these from the Cloudflare dashboard > Turnstile > Add site.
# The SITE_KEY is public (safe to expose); the SECRET_KEY must stay server-only.
# When BOTH are left empty, forms still work and verification is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
